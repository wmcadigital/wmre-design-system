{% macro wmreSearchbar(params) %}

<form class="wmre-search-bar">
    <input aria-label="Search" type="text" class="wmre-search-bar__input wmre-fe-input" placeholder="Search for tickets, timetables, travel advice…">
    <button class="wmre-search-bar__btn" types="submit">
        <svg><title>Search</title><use xlink:href="#wmre-general-search" href="#wmre-general-search"></use></svg>
    </button>
</form>
{% endmacro %}
